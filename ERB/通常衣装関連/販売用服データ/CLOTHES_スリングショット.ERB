@CLOTHES_衣装説明_スリングショット()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 10000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = エロ衣装
;販売させない服はこれに1を入れる
販売禁止フラグ = 0

説明文章 = 
説明文章 += "紐のような形状の水着<br>"
説明文章 += "名前の由来は動物を撃つための武器「パチンコ（投石器）」に形状が似ていることから来ている<br>"
説明文章 += "実は男性用も存在しており、そちらは「マンキニ」もしくは「ムタンガ」と呼ばれている<br>"
説明文章 += "　<br>"
説明文章 += "一応布幅が広いものも存在しているがここの水着は紐を彷彿とさせる細さのものが多いようだ<br>"
説明文章 += "どちらにせよ、これを着るのには余程の胆力か恥知らずの精神性が必要となるだろう<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格

@CLOTHES_CHANGE_スリングショット(対象キャラ)
#DIM 対象キャラ

;一個前の服装を保持
SIF CSTR:対象キャラ:着せ替え服 != "スリングショット"
	CSTR:対象キャラ:脱ぐ前の服 = %CSTR:対象キャラ:着せ替え服%

CSTR:対象キャラ:着せ替え服 = スリングショット
CSTR:対象キャラ:着せ替え服追加名 = 
