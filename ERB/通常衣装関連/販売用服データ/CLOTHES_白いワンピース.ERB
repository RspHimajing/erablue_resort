@CLOTHES_衣装説明_白いワンピース()
#DIMS 説明文章
#DIMS 出典元
#DIM 販売価格
#DIMS 販売分類

;単位はルピ
販売価格 = 10000
;通常衣装、もしくはエロ衣装のどちらか
販売分類 = 通常衣装
;販売させない服はこれに1を入れる
販売禁止フラグ = 0

説明文章 = 
説明文章 += "【蒼の少女】の普段着を本人とデザイナーのエルーン女性の協力もあって再現できた衣類<br>"
説明文章 += "大きさは子供から大人まで女性ハーヴィンから男ドラフ、<br>"
説明文章 += "果てには星晶獣サイズまで取り揃えている　<br>"
説明文章 += "　<br>"
説明文章 += "見た目は白く清純な気配すらあるが一度この衣類に袖を通したものは皆、<br>"
説明文章 += "【蒼の少女】への見方が変わってしまうとのことだが……？<br>"

RESULTS = %説明文章%
RESULTS:1 = %出典元%
RESULTS:2 = %販売分類%

RETURN 販売価格

