@固有アビ_3505_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 36
	アビ名 = ライトニングクロー++
	消費ＭＰ = 500
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 15
	アビ名 = ライトニングクロー+
	消費ＭＰ = 300
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
	アビ名 = ライトニングクロー
	消費ＭＰ = 100
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 36
			詳細文文字列受け渡し変数 = 消費ＭＰ：500
			詳細文文字列受け渡し変数 += "<br>敵単体に［攻撃力✕150％］の自属性ダメージを2回与える。"
			詳細文文字列受け渡し変数 += "<br>敵全体に［攻撃力✕150％］の<font color='#FDEC59'>光属性</font>ダメージを与える。"
			詳細文文字列受け渡し変数 += "<br>自身に［10］（Ｃ枠・3ターン）の高揚上昇効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［2ターン］のバフ効果延長効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 15
			詳細文文字列受け渡し変数 = 消費ＭＰ：300
			詳細文文字列受け渡し変数 += "<br>敵単体に［攻撃力✕90％］の自属性ダメージを2回与える。"
			詳細文文字列受け渡し変数 += "<br>敵全体に［攻撃力✕90％］の<font color='#FDEC59'>光属性</font>ダメージを与える。"
			詳細文文字列受け渡し変数 += "<br>自身に［10］（Ｃ枠・3ターン）のテンション上昇効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
			詳細文文字列受け渡し変数 = 消費ＭＰ：100
			詳細文文字列受け渡し変数 += "<br>敵単体に［攻撃力✕75％］の自属性ダメージを2回与える。"
			詳細文文字列受け渡し変数 += "<br>敵全体に［攻撃力✕70％］の<font color='#FDEC59'>光属性</font>ダメージを与える。"
		ENDIF
		RETURN 消費ＭＰ
	CASE "アビ効果"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 36
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵単体
			アビ汎用変数:効果割合 = 150
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			FOR LOCAL, 0, 2
				CALL アビテンプレート_ダメージ処理_自属性
			NEXT
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体_生者のみ
			アビ汎用変数:効果割合 = 150
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			CALL アビテンプレート_ダメージ処理_光属性
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = 高揚C
			アビ汎用文字列:バフ・デバフ対象能力 = 高揚
			アビ汎用変数:効果量 = 10
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_有利効果_バフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用変数:効果量 = 2
			CALL アビテンプレート_有利効果_バフ効果延長_持続ターン
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 15
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵単体
			アビ汎用変数:効果割合 = 90
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			FOR LOCAL, 0, 2
				CALL アビテンプレート_ダメージ処理_自属性
			NEXT
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体_生者のみ
			アビ汎用変数:効果割合 = 90
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			CALL アビテンプレート_ダメージ処理_光属性
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用文字列:バフ・デバフ枠 = テンションC
			アビ汎用文字列:バフ・デバフ対象能力 = テンション
			アビ汎用変数:効果量 = 10
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_有利効果_バフ効果セット
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵単体
			アビ汎用変数:効果割合 = 75
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			FOR LOCAL, 0, 2
				CALL アビテンプレート_ダメージ処理_自属性
			NEXT
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体_生者のみ
			アビ汎用変数:効果割合 = 70
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			CALL アビテンプレート_ダメージ処理_光属性
		ENDIF
ENDSELECT


