@固有奥義_3504(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIMS 奥義名
#DIM 表示用奥義威力

IF 陥落チェック(キャラ番号)
	奥義名 = プラズマランチャー
	奥義威力 = 0
	表示用奥義威力 = 300
ELSEIF 1
	奥義名 = ロケットランチャー
	奥義威力 = 0
	表示用奥義威力 = 300
ENDIF

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%
	CASE "奥義説明文"
		IF 陥落チェック(キャラ番号)
			詳細文文字列受け渡し変数 = 
			詳細文文字列受け渡し変数 += "<br>敵全体に［300％］（行動速度依存）の自属性ダメージを2回与える。"
		ELSEIF 1
			詳細文文字列受け渡し変数 = 
			詳細文文字列受け渡し変数 += "<br>敵全体に［300％］（行動速度依存）の自属性ダメージを与える。"
		ENDIF
	CASE "奥義追加効果"
		IF 陥落チェック(キャラ番号)
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体_生者のみ
			アビ汎用変数:効果割合 = 300
			アビ汎用文字列:攻撃側使用能力値 = 行動速度
			FOR LOCAL, 0, 2
				CALL アビテンプレート_ダメージ処理_自属性
			NEXT
		ELSEIF 1
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体_生者のみ
			アビ汎用変数:効果割合 = 300
			アビ汎用文字列:攻撃側使用能力値 = 行動速度
			CALL アビテンプレート_ダメージ処理_自属性
		ENDIF
ENDSELECT


 
