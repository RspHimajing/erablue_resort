口上用変数_133ラルナ_回数記録:3 += 1

IF TALENT:対象キャラ:恋慕
	IF RFLAG:コマンド結果受渡し変数 == 1
		;ノってくる
		SELECTCASE RAND:2
    CASE 0
        KSTR:(K++) = 「もう！　そんな事言われたらシたくなっちゃうわ_H_」
    CASE 1
        KSTR:(K++) = 「……_H_　今度はそのプレイでしてみる？_H_」
ENDSELECT
	ENDIF
ELSEIF TALENT:対象キャラ:セフレ
	KSTR:(K++) = 
ELSE
	KSTR:(K++) = 「そ、そうなの……」
	KSTR:(K++) = （え……そ、そんなに気持ちいいの……？　だ、ダメよ私！　結婚してるんだから興味もっちゃ……うぅ……_H_）
	KSTR:(K++) = ラルナは興味ないふりをしているが、顔を赤くしｺﾞｸﾘ…と固唾を呑んだのを%CALLNAME:MASTER%は見逃さなかった。
ENDIF

