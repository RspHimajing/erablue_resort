@固有ターン終了時処理_キャラ_3506
#DIM リリィ隊列

リリィ隊列 = キャラ隊列検索(GETCHARA(3506))
	SELECTCASE RAND:6
		CASE 0
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体
			CALL アビテンプレート_有利効果_デバフ消去
		CASE 1
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体
			CALL アビテンプレート_不利効果_バフ消去
		CASE 2
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体
			アビ汎用変数:効果量 = 1
			CALL アビテンプレート_有利効果_バフ効果延長_持続ターン
		CASE 3
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵全体
			アビ汎用変数:効果量 = 1
			CALL アビテンプレート_不利効果_デバフ効果延長_持続ターン
		CASE 4
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_味方全体
			アビ汎用変数:効果割合 = 5
			アビ汎用文字列:回復側使用能力値 = 回復対象_最大ＭＰ
			CALL アビテンプレート_ＭＰ回復処理_MAXでも回復
		CASE 5
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_自己のみ
			アビ汎用変数:効果量 = 20
			CALL アビテンプレート_有利効果_奥義ゲージUP
	ENDSELECT

@PT編成時ステータス補正_3506(対象キャラ)
#DIM キャラ番号
#DIM 対象キャラ

IF (BATTLE_STATE:隊列算出_味方(GETCHARA(3506)):ＨＰ > 0 || ダンジョン表示モード == "") && BATTLE_STATE:キャラ番号:属性 == 2 && 基礎BATTLE_STATE:キャラ番号:Lv >= 50
	装備ステータス補正保存:対象キャラ:クリティカル率 += 50
ENDIF

;--------------------------------------------------
;戦闘能力画面に表示されるキャラごとの固有処理説明
;--------------------------------------------------
;・使い方
;「XXXX」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;　口上と同じ感覚で使う為に書式を統一しているが、ステータス画面で表示されるので
;　基本的にWAIT系列は使わないことを推奨
;--------------------------------------------------
@口上_ステータス画面_固有特性解説_3506(対象キャラ)
#DIM 対象キャラ
CALL 口上変数初期化

KSTR:(K++) = □ 特性：『百合の女帝　リリーン』 □-------------------------------------------------------
KSTR:(K++) = 　行動終了時以下の効果をランダムで一つ発動する
KSTR:(K++) = 　"味方全体の弱体効果を一つ解除"、"敵全体の強化効果を一つ解除"、
KSTR:(K++) = 　"味方全体の強化効果を1ターン延長"、"敵全体の弱体効果を1ターン延長"
KSTR:(K++) = 　"味方全体のMPを5％回復"、"自身の奥義ゲージ20UP"
IF 基礎BATTLE_STATE:対象キャラ:Lv >= 50
	KSTR:(K++) = □ 特性：『パル愛護団体の塔の守護者』 □-----------------------------------------------------------------
	KSTR:(K++) = 　自身が風属性である時、味方全体のクリティカル率アップ
	KSTR:(K++) = 　
ENDIF
CALL 口上変数表示(対象キャラ, 1)
