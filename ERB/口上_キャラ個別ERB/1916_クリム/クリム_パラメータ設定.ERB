;****************************************
;キャラの初期パラメータを口上側で制御するためのファイル
;****************************************
;・使い方
;「1916」をキャラクター番号に置換し、それぞれの関数に処理を入れる
;****************************************

;--------------------------------------------------
;性別ごと処理制御
;--------------------------------------------------
@性別処理制御_1916(対象キャラ, 動作モード)
#FUNCTION
#DIM 対象キャラ
#DIMS 動作モード
;性別に関わる処理をどうするかを設定する
;男が女性水着を着たり、温泉や更衣室でどっちに入るかなどを制御

;性別変更時に備え、任意の性別表記時のみ実行させる
IF CSTR:対象キャラ:性別表記 == "任意の性別表記（変更すること）"
	SELECTCASE 動作モード
		CASE "服着用性別"
			;特定の性別が服を着替える時、このキャラも同じ服装になる
			;クリスマスパーティでのミニスカサンタ（女性のみ）などが該当
			;RESULT = 1にすると女性、RESULT = 2にすると男性と同じ処理となる
			RESULT = 2
		CASE "入室性別"
			;温泉や更衣室など、性別で部屋が別れている時の処理を制御する
			;RESULT = 1にすると女性、RESULT = 2にすると男性と同じ処理となる
			RESULT = 2
		CASE "業務中セクハラ"
			;雑務業務or給仕業務中の女性キャラを覗くとたまにセクハラされる
			;男性キャラでも発生させるかどうかの制御
			;RESULT = 1にすると発生
			RESULT = 1
	ENDSELECT
ENDIF

