@固有アビ_3507_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 消費ＭＰ
#DIMS アビ名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 32
	アビ名 = スターマイン++
	消費ＭＰ = 150
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 16
	アビ名 = スターマイン+
	消費ＭＰ = 100
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
	アビ名 = スターマイン
	消費ＭＰ = 50
ENDIF

SELECTCASE ARGS
	CASE "アビ名"
		TSTR:コマンド名受渡 = %アビ名%
	CASE "アビ説明文"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 32
			詳細文文字列受け渡し変数 = 消費ＭＰ：150
			詳細文文字列受け渡し変数 += "<br>敵ランダム5体に［攻撃力✕150％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += "<br>［20］（Ｂ枠・3ターン）の回避率減少効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［30］（Ｂ枠・3ターン）の連続攻撃率減少効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［20％］（Ｂ枠・3ターン）の命中率減少効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 16
			詳細文文字列受け渡し変数 = 消費ＭＰ：100
			詳細文文字列受け渡し変数 += "<br>敵ランダム5体に［攻撃力✕120％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += "<br>［10］（Ｂ枠・3ターン）の回避率減少効果を与える。"
			詳細文文字列受け渡し変数 += "<br>［25］（Ｂ枠・3ターン）の連続攻撃率減少効果を与える。"
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
			詳細文文字列受け渡し変数 = 消費ＭＰ：50
			詳細文文字列受け渡し変数 += "<br>敵ランダム5体に［攻撃力✕100％］の自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += "<br>［10］（Ｂ枠・3ターン）の回避率減少効果を与える。"
		ENDIF
	CASE "アビ効果"
		IF 基礎BATTLE_STATE:キャラ番号:Lv >= 32
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵ランダムＸ体(5)
			アビ汎用変数:効果割合 = 150
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			CALL アビテンプレート_ダメージ処理_自属性
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 回避率B
			アビ汎用文字列:バフ・デバフ対象能力 = 回避率
			アビ汎用変数:効果量 = 20
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 連続攻撃率B
			アビ汎用文字列:バフ・デバフ対象能力 = 連続攻撃率
			アビ汎用変数:効果量 = 30
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 命中率B
			アビ汎用文字列:バフ・デバフ対象能力 = 命中率
			アビ汎用変数:効果割合 = 20
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 16
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵ランダムＸ体(5)
			アビ汎用変数:効果割合 = 120
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			CALL アビテンプレート_ダメージ処理_自属性
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 回避率B
			アビ汎用文字列:バフ・デバフ対象能力 = 回避率
			アビ汎用変数:効果量 = 10
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 連続攻撃率B
			アビ汎用文字列:バフ・デバフ対象能力 = 連続攻撃率
			アビ汎用変数:効果量 = 25
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
			CALL アビ汎用変数文字列リセット
			CALL アビ対象選択テンプレート_敵ランダムＸ体(5)
			アビ汎用変数:効果割合 = 100
			アビ汎用文字列:攻撃側使用能力値 = 攻撃力
			CALL アビテンプレート_ダメージ処理_自属性
			CALL アビ汎用変数文字列リセット
			アビ汎用文字列:バフ・デバフ枠 = 回避率B
			アビ汎用文字列:バフ・デバフ対象能力 = 回避率
			アビ汎用変数:効果量 = 10
			アビ汎用変数:持続ターン = 3
			CALL アビテンプレート_不利効果_デバフ効果セット
		ENDIF
ENDSELECT


