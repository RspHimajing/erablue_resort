;--------------------------------------------------
;調教者の射精時
;--------------------------------------------------
@KOJO_ORGASM_被射精_2693(対象キャラ)

#DIM 対象キャラ
#DIM 相手キャラ番号

#DIMS 服装名
#DIMS 画像名

;RFLAG:フィニッシュ場所
	;どこに出されたか  
;RCVAR:対象キャラ:被射精絶頂の強度
	;１以上だと射精された時にキャラも絶頂
	;現状はフィニッシュ場所が0～3の時しか起こらない
CALL 口上変数初期化

相手キャラ番号 = RFLAG:口上用射精キャラ番号

画像名 '= ""
服装名 '= CSTR:対象キャラ:着せ替え服

IF 相手キャラ番号 == MASTER
	;相手があなたの時
	SELECTCASE RFLAG:フィニッシュ場所
		CASE 0
			;膣内
			IF RCVAR:対象キャラ:被射精絶頂の強度
				;射精による快楽で絶頂した時
				;KSTR:(K++) = 
			ELSE
				;KSTR:(K++) = 
			ENDIF
			
			;正常位、後背位、寝バック、対面座位、背面座位、騎乗位、側位、屈曲位、駅弁、背面駅弁、対面立位、立ちバック
			IF MODE_存在判定_完全一致("正常位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-正常位", 服装名)
			ELSEIF MODE_存在判定_完全一致("後背位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-後背位", 服装名)
			ELSEIF MODE_存在判定_完全一致("寝バック", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-寝バック", 服装名)
			ELSEIF MODE_存在判定_完全一致("対面座位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-対面座位", 服装名)
			ELSEIF MODE_存在判定_完全一致("背面座位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-背面座位", 服装名)
			ELSEIF MODE_存在判定_完全一致("騎乗位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-騎乗位", 服装名)
			ELSEIF MODE_存在判定_完全一致("側位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-側位", 服装名)
			ELSEIF MODE_存在判定_完全一致("屈曲位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-屈曲位", 服装名)
			ELSEIF MODE_存在判定_完全一致("駅弁", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-駅弁", 服装名)
			ELSEIF MODE_存在判定_完全一致("背面駅弁", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-背面駅弁", 服装名)
			ELSEIF MODE_存在判定_完全一致("対面立位", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-対面立位", 服装名)
			ELSEIF MODE_存在判定_完全一致("立ちバック", MASTER, 対象キャラ)
				画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-膣内-立ちバック", 服装名)
			ENDIF
		CASE 1
			;腸内
			IF RCVAR:対象キャラ:被射精絶頂の強度
				;射精による快楽で絶頂した時
				;KSTR:(K++) = 
			ELSE
				;KSTR:(K++) = 
			ENDIF
			
			画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-腸内", 服装名)
		CASE 2
			;口
			IF RCVAR:対象キャラ:精飲フラグ > 1
			;喜んで飲む
				IF RCVAR:対象キャラ:被射精絶頂の強度
					;射精による快楽で絶頂した時
					;KSTR:(K++) = 
				ELSE
					;KSTR:(K++) = 
				ENDIF
			ELSEIF RCVAR:対象キャラ:精飲フラグ
			;なんとか飲み込む
				IF RCVAR:対象キャラ:被射精絶頂の強度
					;射精による快楽で絶頂した時
					;KSTR:(K++) = 
				ELSE
					;KSTR:(K++) = 
				ENDIF
			ELSEIF ABL:対象キャラ:技巧 > 2
			;ティッシュに吐き出す
				;KSTR:(K++) = 
			ELSE
			;吐き出してむせる
				;KSTR:(K++) = 
			ENDIF
			
			画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-口", 服装名)
		CASE 3
			;乳内
			IF RCVAR:対象キャラ:被射精絶頂の強度
				;KSTR:(K++) = 
			ELSE
				;KSTR:(K++) = 
			ENDIF
			
			画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-乳内", 服装名)
		CASE 5
			;顔
			;KSTR:(K++) = 
			
            画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-顔", 服装名)
		CASE 6
			;腹
			;KSTR:(K++) = 
			
            画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-腹", 服装名)
		CASE 7
			;背中
			;KSTR:(K++) = 
            
            画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-背中", 服装名)
		CASE 8
			;太もも
			;KSTR:(K++) = 
			
            画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-太もも", 服装名)
		CASE 9
			;手のひら
			;KSTR:(K++) = 
			
            画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-手のひら", 服装名)
		CASE 10
			;足
			;KSTR:(K++) = 
			
            画像名 '= コマンド実行時画像名称変換処理(対象キャラ, "独自-射精時-足", 服装名)
		CASE 30
			IF CFLAG:対象キャラ:うふふ
				;うふふ中汎用射精
				;KSTR:(K++) = 
			ELSE
				;非うふふ時の射精、逆セクハラなど
				;KSTR:(K++) = 
			ENDIF
	ENDSELECT
ENDIF

;CALL 口上変数表示(対象キャラ, 0)

IF 画像名 != ""
	CALL PRINT_STRL(@"IMAGEPATH_%CSTR:対象キャラ:画像フォルダ%/コマンド実行時_%画像名%")
ENDIF
