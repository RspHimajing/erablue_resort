[IF_DEBUG]
;---------------------------------------------------------------------
;【デバッグ用】画像ファイル名のチェック処理＠キャラ指定版
;---------------------------------------------------------------------
@デバッグ用_画像ファイル名チェック_キャラ指定()
#DIM  CSV_NO
#DIM  L_CNT
#DIM  L_CNT_F
#DIMS FOLDER_NAME
#DIMS DYNAMIC FOLDER_LIST, VARSIZE("RESULTS") ; 取得したフォルダリストの格納先
#DIM  FOLDER_CNT
#DIM  DYNAMIC FOLDER_CNT_ALL
#DIM  CSV_NO_F
#DIMS CHARA_NAME_F
#DIM CSV_FLAG

;- 対象入力
PRINTL
PRINTL 【デバッグ用】画像ファイル名のチェック＠キャラ指定版
PRINTL 　※ pngファイルはチェックされません。
PRINTL
CALL デバッグ用_画像ファイル名チェック_キャラ指定_CSV番号入力()
CSV_NO = RESULT
CSV_FLAG = RESULT:1
SIF CSV_NO == -1
	RETURN
PRINTL
REDRAW 0

;- ファイル名チェック実行
; チェック前に情報をリセット
CALL デバッグ用_エラー画像情報管理("リセット")

; フォルダ名のチェック
CALL デバッグ用_画像フォルダ名チェック(CSV_NO)

; CSV番号＋CSV記載のCALLNAMEからフォルダ名を生成
FOLDER_NAME '= TOSTR(CSV_NO) + CSVCALLNAME(CSV_NO)
FOLDER_CNT = デバッグ用_画像ファイル名チェック_フォルダ取得(FOLDER_NAME, FOLDER_LIST)
FOLDER_CNT_ALL += FOLDER_CNT

FOR L_CNT_F, 0, FOLDER_CNT
	IF CSV_FLAG
		ADDCHARA CSV_NO
		CALL デバッグ用_画像ファイル実装状況出力(FOLDER_LIST:L_CNT_F, CHARANUM-1)
		SIF RESULT
			CSV_FLAG = 0
		DELCHARA CHARANUM - 1
	ENDIF
	CALL デバッグ用_画像ファイル名チェック_フォルダ(FOLDER_LIST:L_CNT_F)
NEXT

; 命名規則から外れたリソースフォルダのチェック(0あなた等)
FOR L_CNT, 0, VARSIZE("デバッグ用_特殊リソースフォルダ")
	FOLDER_NAME '= デバッグ用_特殊リソースフォルダ:L_CNT
	;CSV番号が一致するものだけチェック
	CALL デバッグ用_画像ファイル名チェック_画像フォルダ名分解(FOLDER_NAME, CSV_NO_F, CHARA_NAME_F)
	SIF CSV_NO_F != CSV_NO
		CONTINUE
	FOLDER_CNT= デバッグ用_画像ファイル名チェック_フォルダ取得(FOLDER_NAME, FOLDER_LIST)
	FOLDER_CNT_ALL += FOLDER_CNT
	FOR L_CNT_F, 0, FOLDER_CNT
		IF CSV_FLAG
			ADDCHARA CSV_NO
			CALL デバッグ用_画像ファイル実装状況出力(FOLDER_LIST:L_CNT_F, CHARANUM-1)
			SIF RESULT
				CSV_FLAG = 0
			DELCHARA CHARANUM - 1
		ENDIF
		CALL デバッグ用_画像ファイル名チェック_フォルダ(FOLDER_LIST:L_CNT_F)
	NEXT
NEXT

;- 結果の表示
REDRAW 1
AWAIT
;画像フォルダがない場合は結果表示なしで終了
IF FOLDER_CNT_ALL == 0
	PRINTW 指定されたキャラの画像フォルダが見つかりませんでした。
	RETURN
ENDIF

CALL デバッグ用_エラー画像情報管理("結果出力")

;- 結果のファイル出力
PRINTL
PRINTL 結果をファイルに出力しますか？
PRINTL
PRINTBUTTONLC "[0] はい", 0
PRINTBUTTONLC "[1] いいえ", 1
BINPUT
SIF RESULT == 1
	RETURN

; ファイル保存実行
; RESULT:保存成否 RESULTS:保存したファイルのパス
FOLDER_NAME '= TOSTR(CSV_NO) + CSVCALLNAME(CSV_NO)
CALL デバッグ用_エラー画像情報管理("ファイル保存", FOLDER_NAME)
IF RESULT
	; ファイル保存成功
	PRINTFORML 結果を「%RESULTS%」に保存しました
ELSE
	; ファイル保存失敗
	PRINTL ファイルの保存に失敗しました
ENDIF
PRINTW

;---------------------------------------------------------------------
;【デバッグ用】チェック対象のCSV番号入力処理
;---------------------------------------------------------------------
@デバッグ用_画像ファイル名チェック_キャラ指定_CSV番号入力()
#DIM CSV_NO

;- チェック対象の指定
PRINTL
PRINTL
PRINTL チェックしたいキャラのCSV番号を入力してください(0でキャンセル)

;入力処理
INPUT
CSV_NO = RESULT
;0でキャンセル
SIF CSV_NO == 0
	RETURN 0
;対応するキャラが居ない場合は再入力
IF !EXISTCSV(CSV_NO)
	PRINTW 入力されたCSV番号のキャラは存在しません。
	RESTART
ENDIF

;- チェック対象の確認
PRINTL
PRINTL
PRINTFORML チェックするのは下記のキャラでよろしいですか？
DRAWLINE
PRINTFORML <CSV番号>
PRINTFORML {CSV_NO}
PRINTL
PRINTFORML <名前>
PRINTFORML %CSVNAME(CSV_NO)%
PRINTL
PRINTFORML <呼び名>
PRINTFORML %CSVCALLNAME(CSV_NO)%
PRINTL
PRINTFORML <画像フォルダ名>
PRINTFORML {CSV_NO}%CSVCALLNAME(CSV_NO)%
DRAWLINE
PRINTBUTTONLC "[0] はい", 0
PRINTBUTTONLC "[1] いいえ", 1
PRINTBUTTONLC "[2] チェックをやめる", 2
PRINTBUTTONLC "[3] 実装状況も出力する", 3

;入力処理
BINPUT
SELECTCASE RESULT
	CASE 0
		; はい
		RESULT:1 = 0
		RETURN CSV_NO
	CASE 1
		; いいえ
		RESTART
	CASE 2
		; やめる
		RETURN -1
	CASE 3
		; 実装状況も出力する
		RESULT:1 = 1
		RETURN CSV_NO
ENDSELECT

;---------------------------------------------------------------------
;【デバッグ用】チェック対象の衣装と行為差分の画像実装状況を表にして出力する
;---------------------------------------------------------------------

@デバッグ用_画像ファイル実装状況出力(FOLDER_NAME, ARG)
#DIMS FOLDER_NAME
#DIMS DYNAMIC CLTH_LIST , VARSIZE("RESULTS")
#DIMS DYNAMIC DEF_LIST , VARSIZE("RESULTS")
#DIM CLTH_CNT
#DIM DEF_CNT
#DIM L_CNT
#DIM L_CNT_C
#DIM L_CNT_D

;出力用データベースを作成
DT_CREATE FOLDER_NAME
;衣装リスト、差分リストだけ拾うために既存関数を利用
CALLF デバッグ用_画像ファイル名チェック_ファイル("", FOLDER_NAME)
SPLIT TSTR:0, "|", DEF_LIST
DEF_CNT = RESULT

DT_COLUMN_ADD FOLDER_NAME, "衣装名"
;最初の方に使用頻度の高そうな差分を持ってくる
DT_COLUMN_ADD FOLDER_NAME, "ベース", 1
DT_COLUMN_ADD FOLDER_NAME, "表情", 1
DT_COLUMN_ADD FOLDER_NAME, "欲情", 1
DT_COLUMN_ADD FOLDER_NAME, "絶頂", 1
DT_COLUMN_ADD FOLDER_NAME, "正常位", 1
DT_COLUMN_ADD FOLDER_NAME, "後背位", 1
DT_COLUMN_ADD FOLDER_NAME, "Ａ正常位", 1
DT_COLUMN_ADD FOLDER_NAME, "Ａ後背位", 1
DT_COLUMN_ADD FOLDER_NAME, "フェラチオ", 1
DT_COLUMN_ADD FOLDER_NAME, "パイズリ", 1
DT_COLUMN_ADD FOLDER_NAME, "膣内射精", 1
DT_COLUMN_ADD FOLDER_NAME, "腸内射精", 1
DT_COLUMN_ADD FOLDER_NAME, "口内射精", 1
DT_COLUMN_ADD FOLDER_NAME, "乳内射精", 1
DT_COLUMN_ADD FOLDER_NAME, "顔射", 1
;差分リストから追記
FOR L_CNT_D, 0, DEF_CNT
	SIF DEF_LIST:L_CNT_D == ""
		CONTINUE
	DT_COLUMN_ADD FOLDER_NAME, @"%DEF_LIST:L_CNT_D%", 1
NEXT

SPLIT TSTR:1, "|", CLTH_LIST
CLTH_CNT = RESULT
;デフォルト、水着、おしゃれ着、浴衣、バスローブは複数種類設定可能なのでサーチする
LOCAL = CLTH_CNT
FOR L_CNT_C, 0, CLTH_CNT
	IF CLTH_LIST:L_CNT_C == ""
		;DEBUGPRINTFORM [%CLTH_LIST:L_CNT_C%]{L_CNT_C}番目
		CONTINUE
	ENDIF
	;着用条件を満たしていない衣装はスキップ
	DO
		TRYCCALLFORM CLOTHES_着用条件_%CLTH_LIST:L_CNT_C%(ARG)
			IF !RESULT
				;DEBUGPRINTFORM [%CLTH_LIST:L_CNT_C%]は着れないので除外して
				ARRAYREMOVE CLTH_LIST, L_CNT_C, 1
				;DEBUGPRINTFORML %CLTH_LIST:L_CNT_C%になる
				LOCAL --
			ELSE
				;DEBUGPRINTFORM [%CLTH_LIST:L_CNT_C%]
				BREAK
			ENDIF
		CATCH
			;DEBUGPRINTFORM [%CLTH_LIST:L_CNT_C%]
			BREAK
		ENDCATCH
	LOOP 1
	IF GROUPMATCH(CLTH_LIST:L_CNT_C, "デフォルト", "水着", "おしゃれ着", "浴衣" ,"バスローブ")
		LOCAL:1 = GET_RESOURCES_FILES(FOLDER_NAME, @"短冊_%CLTH_LIST:L_CNT_C%*_差分_*.webp")
		LOCAL:2 = GET_RESOURCES_FILES(FOLDER_NAME, @"短冊_%CLTH_LIST:L_CNT_C%*.webp")
		;DEBUGPRINTFORML の差分数{LOCAL:1} / 総数{LOCAL:2}
		IF LOCAL:1 + 1 < LOCAL:2
			FOR L_CNT, 0, LOCAL:2
				;DEBUGPRINTFORM %RESULTS:L_CNT%は
				IF STRCOUNT(RESULTS:L_CNT, "差分")
					;DEBUGPRINTL 差分の文字を含むので除外
					CONTINUE
				ENDIF
				LOCALS '= REPLACE(RESULTS:L_CNT, "短冊_", "")
				;DEBUGPRINTFORM %LOCALS%→
				LOCALS '= REPLACE(LOCALS, "\.webp", "")
				;DEBUGPRINTFORM %LOCALS%→
				IF MATCH(CLTH_LIST, LOCALS)
					;DEBUGPRINTL 同じなので除外
					CONTINUE
				ENDIF
				;DEBUGPRINTFORM ［%CLTH_LIST:LOCAL%］の欄に
				CLTH_LIST:LOCAL '= LOCALS
				;DEBUGPRINTFORML %CLTH_LIST:LOCAL%として登録
				LOCAL ++
			NEXT
		ENDIF
	ELSE
		;DEBUGPRINTL
	ENDIF
NEXT
LOCAL --
CLTH_CNT = LOCAL

;妊娠差分追加
FOR L_CNT_C, 0, CLTH_CNT
	SIF CLTH_LIST:L_CNT_C == ""
		CONTINUE
	SIF MATCH(CLTH_LIST, "妊娠" + CLTH_LIST:L_CNT_C)
		CONTINUE
	SIF STRCOUNT(CLTH_LIST:L_CNT_C, "妊娠")
		CONTINUE
	;DEBUGPRINTFORM ［%CLTH_LIST:LOCAL%］の欄に
	CLTH_LIST:LOCAL '= "妊娠" + CLTH_LIST:L_CNT_C
	;DEBUGPRINTFORML %CLTH_LIST:LOCAL%として登録
	LOCAL ++
NEXT
CLTH_CNT = LOCAL


;衣装ごとの差分数をカウントして記録
FOR L_CNT_C, 0, CLTH_CNT
	DT_ROW_ADD FOLDER_NAME, "衣装名", CLTH_LIST:L_CNT_C
	DT_CELL_SET FOLDER_NAME, L_CNT_C, "ベース", GET_RESOURCES_FILES(FOLDER_NAME, @"短冊_%CLTH_LIST:L_CNT_C%.webp", 1)
	FOR L_CNT_D, 0, DEF_CNT
		LOCALS '= "短冊_" + CLTH_LIST:L_CNT_C + "_差分_" + DEF_LIST:L_CNT_D
		LOCAL = GET_RESOURCES_FILES(FOLDER_NAME, LOCALS + "*.*", 1)
		IF !STRCOUNT(DEF_LIST:L_CNT_D, "射精")
			LOCAL -= GET_RESOURCES_FILES(FOLDER_NAME, LOCALS + "*射精*.*", 1)
		ENDIF
		DT_CELL_SET FOLDER_NAME, L_CNT_C, DEF_LIST:L_CNT_D, LOCAL
		CALL デバッグ用_チェック用ウェイト処理(@"%FOLDER_NAME%内の%CLTH_LIST:L_CNT_C%の画像カウント中")
	NEXT
NEXT

LOCAL = データベースCSV出力(FOLDER_NAME, "debug/" + FOLDER_NAME + ".csv")
DT_CLEAR FOLDER_NAME

CALL CHOICE(@"%FOLDER_NAME%フォルダのデータベースを出力しました。出力を中断しますか？", "いいえ", "はい")
IF RESULT
	RETURN 1
ENDIF
RETURN 0
[ENDIF]
