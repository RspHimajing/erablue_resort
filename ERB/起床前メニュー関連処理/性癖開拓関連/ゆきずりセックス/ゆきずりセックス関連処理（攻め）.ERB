;==================================================================================================
; ゆきずりセックス関連処理（攻め）
; 男性キャラクターが見知らぬ女性を相手にする場合の処理。
; 発生判定、残時間、相手の絶頂値などは既存処理のTCVARを共用する。
;==================================================================================================

;==================================================================================================
@ゆきずりセックス継続判定_攻め(ARG)
;-------------------------------------------------
;男性キャラクターのゆきずりセックス継続処理
;--------------------------------------------------------------------------------------------------

;対象の隠密状態を継続
CFLAG:ARG:隠密 = 1

;時間が経過しないコマンドの場合は能力変動を行わない
IF TIME_PROGRESS(TFLAG:行動前時刻)
	TCVAR:ARG:ゆきずりセックス_残時間 = MAX(0, TCVAR:ARG:ゆきずりセックス_残時間 - TIME_PROGRESS(TFLAG:行動前時刻))

	;覗き処理側ですでに更新済みなら二重に加算しない
	IF !TCVAR:ARG:ゆきずりセックス_覗きフラグ
		CALL ゆきずりセックス_絶頂値更新_攻め(ARG, TIME_PROGRESS(TFLAG:行動前時刻))
		CALL ゆきずりセックス_パラメータ変動処理_攻め(ARG, TIME_PROGRESS(TFLAG:行動前時刻))
	ENDIF
ENDIF

TCVAR:ARG:ゆきずりセックス_覗きフラグ = 0
CALL ゆきずりセックス_遭遇処理(ARG)

IF IS_ゆきずりセックス中(ARG)
	RETURN 1
ELSE
	IF CFLAG:ARG:同室
		SETCOLOR カラーパレット("えっちな色")
		PRINTFORML 満足げな%CALLNAME:ARG%が見知らぬ女と物陰から出てきた……
		RESETCOLOR
	ENDIF

	TCVAR:ARG:ゆきずりセックス_体位 = 0
	TCVAR:ARG:ゆきずりセックス_残時間 = 0
	TCVAR:ARG:ゆきずりセックス_絶頂値 = 0
	TCVAR:ARG:ゆきずりセックス_終了時刻 = NOW()
	TCVAR:ARG:覗きバレ = 0
	CFLAG:ARG:隠密 = 0
	RETURN 0
ENDIF


;==================================================================================================
@ゆきずりセックス_絶頂値更新_攻め(ARG, 経過時間)
;-------------------------------------------------
;相手女性の絶頂値を更新する
;--------------------------------------------------------------------------------------------------
#DIM 経過時間
#DIM 変動値
;--------------------------------------------------------------------------------------------------
IF TCVAR:ARG:ゆきずりセックス_絶頂値 > 0
	変動値 = 20 + ABL:ARG:欲望 + ABL:ARG:技巧
	変動値 *= 経過時間
	変動値 /= 10
	TCVAR:ARG:ゆきずりセックス_絶頂値 = MAX(0, TCVAR:ARG:ゆきずりセックス_絶頂値 - 変動値)
ELSE
	TCVAR:ARG:ゆきずりセックス_絶頂値 = 100
ENDIF


;==================================================================================================
@ゆきずりセックス_パラメータ変動処理_攻め(ARG, 経過時間=1)
;-------------------------------------------------
;男性キャラクター側の絶頂・射精・性欲減少を処理する
;--------------------------------------------------------------------------------------------------
#DIM 経過時間
#DIM 絶頂閾値
#DIM ループ変数
#DIM 絶頂数
;--------------------------------------------------------------------------------------------------
絶頂閾値 = MAX(5, 20 - TALENT:ARG:Ｃ感度)
絶頂数 = 0

FOR ループ変数, 0, 経過時間/絶頂閾値
	CALL ゆきずりセックス_射精加算_攻め(ARG)
	絶頂数 ++
NEXT
IF 経過時間%絶頂閾値 > RAND:絶頂閾値
	CALL ゆきずりセックス_射精加算_攻め(ARG)
	絶頂数 ++
ENDIF

IF 絶頂数
	CALL ZP_取得処理(ARG, 絶頂数, 0)
	BASE:ARG:性欲 = MAX(BASE:ARG:性欲 - 100 * 絶頂数, 0)
ENDIF


;==================================================================================================
@ゆきずりセックス_射精加算_攻め(ARG)
;-------------------------------------------------
;男性キャラクターが絶頂・射精した時の経験加算
;--------------------------------------------------------------------------------------------------
EXP:ARG:Ｃ絶頂経験 ++
EXP:ARG:射精経験 ++
EXP:ARG:絶頂経験 ++


;==================================================================================================
@ゆきずりセックス_覗く_攻め(ARG)
;-------------------------------------------------
;男性キャラクターのゆきずりセックスを覗き見る処理
;--------------------------------------------------------------------------------------------------
TCVAR:ARG:ゆきずりセックス_覗きフラグ = 1
TIME += 12

;覗き見3分とイベント経過12分を合わせて15分進行
CALL ゆきずりセックス_絶頂値更新_攻め(ARG, 15)

PRINTFORM 物陰を覗き見ると、
SELECTCASE TCVAR:ARG:ゆきずりセックス_体位
	CASE 1
		PRINTFORML %CALLNAME:ARG%が見知らぬ女の膣を激しく貫いている姿を目撃した。
	CASE 2
		PRINTFORML %CALLNAME:ARG%が見知らぬ女の尻を抱え、後ろの穴を犯している姿を目撃した。
	CASEELSE
		PRINTFORML 見知らぬ女が%CALLNAME:ARG%のペニスに熱心に奉仕している姿を目撃した。
ENDSELECT
PRINTW

CALL ゆきずりセックス_相手女性描写_攻め(ARG)
CALL ゆきずりセックス_行為描写_攻め(ARG)

IF TCVAR:ARG:ゆきずりセックス_絶頂値 > 0
	CALL ゆきずりセックス_覗き反応描写_攻め(ARG)
ELSE
	CALL ゆきずりセックス_相手絶頂描写_攻め(ARG)
ENDIF

CALL ゆきずりセックス_パラメータ変動処理_攻め(ARG, 15)


;==================================================================================================
@ゆきずりセックス_相手女性描写_攻め(ARG)
;-------------------------------------------------
;相手女性の属性、誘った側、対象の性癖段階ごとの初回描写
;各CASEの見出し直下へ、そのシチュエーション固有の文章を追加する
;--------------------------------------------------------------------------------------------------
SIF TCVAR:ARG:ゆきずりセックス_相手描写
	RETURN

PRINTFORM 相手は
SELECTCASE TCVAR:ARG:ゆきずりセックス_相手モブ
	CASE 0
		;▼恋愛や性行為に不慣れそうな成人女性
		PRINTFORM %TEXTR("恋愛慣れしていなさそうな/大人しそうな")%若い女
	CASE 1
		;▼余裕のある年上の女性
		PRINTFORM 艶のある年上の女
	CASE 2
		;▼小柄な成人女性
		PRINTFORM 小柄な成人女性
	CASE 3
		;▼快活で旅慣れた若い女性
		PRINTFORM 快活そうな若い女
	CASE 4
		;▼派手で遊び慣れていそうな女性
		PRINTFORM 派手な格好をした女
	CASE 5
		;▼上品で落ち着いた熟女
		PRINTFORM 上品な雰囲気の熟女
	CASE 6
		;▼仕事や日常を忘れて羽目を外している女性旅行客
		PRINTFORM 一人旅らしい女性客
	CASE 7
		;▼特別な特徴のない、ごく普通の女性旅行客
		PRINTFORM ごく普通の女性客
ENDSELECT
PRINTFORML だ。

IF TCVAR:ARG:ゆきずりセックス_誘い
	;▼女性側から%CALLNAME:ARG%を誘ったシチュエーション
	PRINTFORML 女の方から%CALLNAME:ARG%へ声をかけ、この物陰まで連れ込んだらしい。
ELSE
	;▼%CALLNAME:ARG%から女性へ声をかけたシチュエーション
	PRINTFORML %CALLNAME:ARG%が女へ声をかけ、その気にさせて物陰へ誘ったようだ。
ENDIF

SELECTCASE 性癖素質:ARG:ゆきずりセックス（攻め）
	CASE 1
		;▼興味段階。まだ慣れておらず、背徳感や緊張が残る
		PRINTFORML その振る舞いにはまだ僅かな緊張が残っているが、引き返すつもりはないらしい。
	CASE 2
		;▼愛好段階。手慣れており、一期一会の関係を楽しんでいる
		PRINTFORML こうした一期一会の関係にも慣れているのか、%CALLNAME:ARG%の振る舞いには余裕が感じられる。
	CASE 3
		;▼中毒段階。相手を見つけて欲望を発散することが日常化している
		PRINTFORML %CALLNAME:ARG%にとっては、見知らぬ女を抱くことも日常の一部に過ぎないのだろう。
ENDSELECT
PRINTW

TCVAR:ARG:ゆきずりセックス_相手描写 = 1


;==================================================================================================
@ゆきずりセックス_行為描写_攻め(ARG)
;-------------------------------------------------
;具体的なプレイ内容ごとの描写
;各CASEがそのまま文章追加用の枠になる
;--------------------------------------------------------------------------------------------------
SELECTCASE CSTR:ARG:ゆきずりセックス_プレイ内容
	CASE "正常位"
		;▼Ｖ正常位：正面から表情を見ながら抱く
		PRINTFORMW %CALLNAME:ARG%は女を組み敷き、正面から表情を確かめながら腰を進めている。
	CASE "後背位"
		;▼Ｖ後背位：背後から腰や尻を掴んで責める
		PRINTFORMW %CALLNAME:ARG%は女の腰を掴み、背後から欲望のままに突き上げている。
	CASE "寝バック"
		;▼Ｖ寝バック：女へ覆い被さり、密着して責める
		PRINTFORMW %CALLNAME:ARG%は横たわる女へ覆い被さり、逃がさぬよう密着して腰を打ちつけている。
	CASE "騎乗位"
		;▼Ｖ騎乗位：女性が跨がるが、主導権は%CALLNAME:ARG%側
		PRINTFORMW 女を自身の上へ跨がらせた%CALLNAME:ARG%は、その腰を掴んで好きなように動かしている。
	CASE "対面立位"
		;▼Ｖ対面立位：抱き上げる、壁へ押しつける等の正面立位
		PRINTFORMW %CALLNAME:ARG%は女の体を支え、互いの顔が触れそうな距離で立ったまま交わっている。
	CASE "立ちバック"
		;▼Ｖ立ちバック：壁や物陰へ押しつけ、背後から責める
		PRINTFORMW %CALLNAME:ARG%は女を物陰へ押しつけ、背後から腰を打ちつけている。

	CASE "Ａ正常位"
		;▼Ａ正常位：正面から反応を見ながら尻を責める
		PRINTFORMW %CALLNAME:ARG%は女の脚を開かせ、表情を眺めながら後ろの穴を責めている。
	CASE "Ａ後背位"
		;▼Ａ後背位：尻を広げさせ、背後から責める
		PRINTFORMW %CALLNAME:ARG%は女の尻を掴み、晒された後ろの穴を背後から貫いている。
	CASE "Ａ寝バック"
		;▼Ａ寝バック：体重を預け、密着して尻を責める
		PRINTFORMW %CALLNAME:ARG%は女の背へ体を重ね、押さえ込むようにして尻を責め続けている。
	CASE "Ａ騎乗位"
		;▼Ａ騎乗位：女性を上へ跨がらせて尻を使わせる
		PRINTFORMW 女を自身の上へ跨がらせた%CALLNAME:ARG%は、その腰を操って後ろの穴を使わせている。
	CASE "Ａ対面立位"
		;▼Ａ対面立位：正面から抱えたまま尻へ挿入
		PRINTFORMW %CALLNAME:ARG%は女を正面から抱え上げ、立ったまま後ろの穴を貫いている。
	CASE "Ａ立ちバック"
		;▼Ａ立ちバック：立たせた女性を背後から押さえて尻を責める
		PRINTFORMW %CALLNAME:ARG%は女の背を押さえつけ、立たせたまま尻を激しく責めている。

	CASE "フェラチオ"
		;▼女性から口で奉仕を受けている
		PRINTFORMW 女は膝をつき、%CALLNAME:ARG%のペニスへ熱心に口で奉仕している。
	CASEELSE
		;▼将来プレイ内容が追加された場合の汎用描写
		PRINTFORMW %CALLNAME:ARG%と女は%CSTR:ARG:ゆきずりセックス_プレイ内容%で、その場限りの快楽を貪っている。
ENDSELECT


;==================================================================================================
@ゆきずりセックス_覗き反応描写_攻め(ARG)
;-------------------------------------------------
;覗きがバレたか、誰が誘ったか、直接覗きか使い魔かで分岐
;--------------------------------------------------------------------------------------------------
IF !TCVAR:ARG:覗きバレ && RAND:10 < 1
	TCVAR:ARG:覗きバレ = 1
ENDIF

IF TCVAR:ARG:覗きバレ
	IF TCVAR:ARG:使い魔覗き中
		;▼使い魔による覗きに気付いたシチュエーション
		PRINTFORML %CALLNAME:ARG%は使い魔の視線に気付いたらしく、こちらを意識するように顔を上げた。
	ELSE
		;▼%CALLNAME:PLAYER%本人の覗きに気付いたシチュエーション
		PRINTFORML %CALLNAME:ARG%はこちらの視線に気付き、確かめるように一瞬だけ目を向けた。
	ENDIF

	IF TCVAR:ARG:ゆきずりセックス_誘い
		;▼女性に誘われた最中、見られても行為を続ける
		PRINTFORMW 見知らぬ女に求められている姿を見られても、%CALLNAME:ARG%は手を止めることなく行為を続けた……
	ELSE
		;▼自分から女性を誘った最中、見られても行為を続ける
		PRINTFORMW 自ら女を誘ったことを隠す様子もなく、%CALLNAME:ARG%は行為を見せつけるように続けた……
	ENDIF
ELSE
	IF TCVAR:ARG:ゆきずりセックス_誘い
		;▼女性に誘われ、覗きに気付かず夢中になっている
		PRINTFORMW 二人は覗かれていることに気付かず、女に求められるままその場限りの快楽へ没頭している……
	ELSE
		;▼自分から女性を誘い、覗きに気付かず夢中になっている
		PRINTFORMW 二人は覗かれていることに気付かず、%CALLNAME:ARG%が望んだその場限りの快楽へ没頭している……
	ENDIF
ENDIF


;==================================================================================================
@ゆきずりセックス_相手絶頂描写_攻め(ARG)
;-------------------------------------------------
;相手女性の絶頂と、その後の延長・終了描写
;--------------------------------------------------------------------------------------------------
SELECTCASE TCVAR:ARG:ゆきずりセックス_体位
	CASE 1
		;▼Ｖ挿入中に相手女性が絶頂
		PRINTFORML 丁度女が絶頂を迎えたらしく、%CALLNAME:ARG%の体へ縋りつきながら激しく身を震わせた。
	CASE 2
		;▼Ａ挿入中に相手女性が絶頂
		PRINTFORML 尻を責められていた女は限界を迎え、%CALLNAME:ARG%へ縋りつきながら激しく身を震わせた。
	CASEELSE
		;▼奉仕中の女性が興奮の限界を迎えた
		PRINTFORML 奉仕を続けていた女は自らも興奮を抑えきれなくなり、熱っぽい息を漏らしながら身を震わせた。
ENDSELECT

IF TCVAR:ARG:ゆきずりセックス_残時間
	IF TCVAR:ARG:ゆきずりセックス_誘い
		;▼女性側が続きを求めて延長戦へ
		PRINTFORMW 一度では足りないらしく、女は再び%CALLNAME:ARG%を求め、そのまま次の交わりを始めた……
	ELSE
		;▼%CALLNAME:ARG%側が続きを求めて延長戦へ
		PRINTFORMW それでも満足しない%CALLNAME:ARG%は女を離さず、すぐに次の交わりを始めた……
	ENDIF
ELSE
	IF TCVAR:ARG:覗きバレ
		;▼覗きがバレている状態で行為終了
		PRINTFORMW 満足した二人が服を整え始め、%CALLNAME:ARG%もこちらへ目を向けたため、%CALLNAME:PLAYER%は急いでその場を離れた。
	ELSE
		;▼覗きに気付かれないまま行為終了
		PRINTFORMW 満足した二人が服を整え始めたため、%CALLNAME:PLAYER%は気付かれないよう静かにその場を離れた。
	ENDIF
ENDIF


;==================================================================================================
@ゆきずりセックス内容決定_攻め(ARG)
;-------------------------------------------------
;男性キャラクターが見知らぬ女性に行うプレイ内容を決定する
;体位0:奉仕を受ける、1:Ｖ挿入、2:Ａ挿入
;--------------------------------------------------------------------------------------------------
#DIMS プレイ内容
#DIM Ｖ性交重み
#DIM Ａ性交重み
#DIM 奉仕重み
#DIM 重み合計
;--------------------------------------------------------------------------------------------------

;途中終了後に前回の体位を持ち越さない
TCVAR:ARG:ゆきずりセックス_体位 = 0

;純潔設定が有効な場合、未経験の挿入先は候補から外す
SIF !(OPTION変数:夜這い処女・童貞 && !GETBIT(TALENT:ARG:非童貞, 0))
	Ｖ性交重み = MAX(1, ABL:ARG:技巧)
SIF !(OPTION変数:夜這い処女・童貞 && !GETBIT(TALENT:ARG:非童貞, 1))
	Ａ性交重み = MAX(1, ABL:ARG:技巧 / 2)

;相手から誘われた場合は口で奉仕される可能性を加える
SIF TCVAR:ARG:ゆきずりセックス_誘い
	奉仕重み = MAX(1, ABL:ARG:欲望)

重み合計 = Ｖ性交重み + Ａ性交重み + 奉仕重み

IF 重み合計
	SELECTCASE RAND:重み合計
		CASE IS < 奉仕重み
			プレイ内容 = フェラチオ

		CASE 奉仕重み TO 奉仕重み+Ｖ性交重み-1
			SELECTCASE RAND:6
				CASE 0
					プレイ内容 = 正常位
				CASE 1
					プレイ内容 = 後背位
				CASE 2
					プレイ内容 = 寝バック
				CASE 3
					プレイ内容 = 騎乗位
				CASE 4
					プレイ内容 = 対面立位
				CASE 5
					プレイ内容 = 立ちバック
			ENDSELECT
			TCVAR:ARG:ゆきずりセックス_体位 = 1
			IF !GETBIT(TALENT:ARG:非童貞, 0)
				CALL 履歴データベース登録(CFLAG:ARG:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>出会ったばかりの女性に自ら童貞を捧げてしまった</font><img src='えっちハート'>","うふふ")
			ENDIF
			SETBIT TALENT:ARG:非童貞, 0
			EXP:ARG:Ｃ性交経験_Ｖ挿入 ++

		CASEELSE
			SELECTCASE RAND:6
				CASE 0
					プレイ内容 = Ａ正常位
				CASE 1
					プレイ内容 = Ａ後背位
				CASE 2
					プレイ内容 = Ａ寝バック
				CASE 3
					プレイ内容 = Ａ騎乗位
				CASE 4
					プレイ内容 = Ａ対面立位
				CASE 5
					プレイ内容 = Ａ立ちバック
			ENDSELECT
			TCVAR:ARG:ゆきずりセックス_体位 = 2
			IF !GETBIT(TALENT:ARG:非童貞, 1)
				CALL 履歴データベース登録(CFLAG:ARG:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>出会ったばかりの女性で初めてアナルへ挿入した</font><img src='えっちハート'>","うふふ")
			ENDIF
			SETBIT TALENT:ARG:非童貞, 1
			EXP:ARG:Ｃ性交経験_Ａ挿入 ++
	ENDSELECT
ELSE
	;純潔設定で挿入できず、相手を誘った場合も最低限の行為を成立させる
	プレイ内容 = フェラチオ
ENDIF

CSTR:ARG:ゆきずりセックス_プレイ内容 = %プレイ内容%
