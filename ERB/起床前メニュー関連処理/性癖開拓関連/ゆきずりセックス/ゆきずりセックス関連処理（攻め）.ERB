; ゆきずりセックス関連処理（攻め）
; 男性キャラクターが見知らぬ女性を相手にする場合の処理。
; 発生判定、残時間、相手の絶頂値などは既存処理のTCVARを共用する。
;==================================================================================================

;==================================================================================================
@ゆきずりセックス継続判定_攻め(ARG)
;-------------------------------------------------
;男性キャラクターのゆきずりセックス継続処理
;--------------------------------------------------------------------------------------------------

;対象の隠密状態を継続
CFLAG:ARG:隠密 = 1

;時間が経過しないコマンドの場合は能力変動を行わない
IF TIME_PROGRESS(TFLAG:行動前時刻)
	TCVAR:ARG:ゆきずりセックス_残時間 = MAX(0, TCVAR:ARG:ゆきずりセックス_残時間 - TIME_PROGRESS(TFLAG:行動前時刻))

	;覗き処理側ですでに更新済みなら二重に加算しない
	IF !TCVAR:ARG:ゆきずりセックス_覗きフラグ
		CALL ゆきずりセックス_絶頂値更新_攻め(ARG, TIME_PROGRESS(TFLAG:行動前時刻))
		CALL ゆきずりセックス_パラメータ変動処理_攻め(ARG, TIME_PROGRESS(TFLAG:行動前時刻))
	ENDIF
ENDIF

TCVAR:ARG:ゆきずりセックス_覗きフラグ = 0
CALL ゆきずりセックス_遭遇処理(ARG)

IF IS_ゆきずりセックス中(ARG)
	RETURN 1
ELSE
	IF CFLAG:ARG:同室
		SETCOLOR カラーパレット("えっちな色")
		PRINTFORML 満足げな%CALLNAME:ARG%が見知らぬ女と物陰から出てきた……
		RESETCOLOR
	ENDIF

	TCVAR:ARG:ゆきずりセックス_体位 = 0
	TCVAR:ARG:ゆきずりセックス_残時間 = 0
	TCVAR:ARG:ゆきずりセックス_絶頂値 = 0
	TCVAR:ARG:ゆきずりセックス_終了時刻 = NOW()
	TCVAR:ARG:覗きバレ = 0
	CFLAG:ARG:隠密 = 0
	RETURN 0
ENDIF


;==================================================================================================
@ゆきずりセックス_絶頂値更新_攻め(ARG, 経過時間)
;-------------------------------------------------
;相手女性の絶頂値を更新する
;--------------------------------------------------------------------------------------------------
#DIM 経過時間
#DIM 変動値
;--------------------------------------------------------------------------------------------------
IF TCVAR:ARG:ゆきずりセックス_絶頂値 > 0
	変動値 = 20 + ABL:ARG:欲望 + ABL:ARG:技巧
	変動値 *= 経過時間
	変動値 /= 10
	TCVAR:ARG:ゆきずりセックス_絶頂値 = MAX(0, TCVAR:ARG:ゆきずりセックス_絶頂値 - 変動値)
ELSE
	TCVAR:ARG:ゆきずりセックス_絶頂値 = 100
ENDIF


;==================================================================================================
@ゆきずりセックス_パラメータ変動処理_攻め(ARG, 経過時間=1)
;-------------------------------------------------
;男性キャラクター側の絶頂・射精・性欲減少を処理する
;--------------------------------------------------------------------------------------------------
#DIM 経過時間
#DIM 絶頂閾値
#DIM ループ変数
#DIM 絶頂数
;--------------------------------------------------------------------------------------------------
絶頂閾値 = MAX(5, 20 - TALENT:ARG:Ｃ感度)
絶頂数 = 0

FOR ループ変数, 0, 経過時間/絶頂閾値
	CALL ゆきずりセックス_射精加算_攻め(ARG)
	絶頂数 ++
NEXT
;経過時間の端数に応じて、追加の絶頂が発生するか判定する
IF 経過時間%絶頂閾値 > RAND:絶頂閾値
	CALL ゆきずりセックス_射精加算_攻め(ARG)
	絶頂数 ++
ENDIF

IF 絶頂数
	CALL ZP_取得処理(ARG, 絶頂数, 0)
	BASE:ARG:性欲 = MAX(BASE:ARG:性欲 - 100 * 絶頂数, 0)
ENDIF


;==================================================================================================
@ゆきずりセックス_射精加算_攻め(ARG)
;-------------------------------------------------
;男性キャラクターが絶頂・射精した時の経験加算
;--------------------------------------------------------------------------------------------------
EXP:ARG:Ｃ絶頂経験 ++
EXP:ARG:射精経験 ++
EXP:ARG:絶頂経験 ++


;==================================================================================================
@ゆきずりセックス_覗く_攻め(ARG)
;-------------------------------------------------
;男性キャラクターのゆきずりセックスを覗き見る処理
;--------------------------------------------------------------------------------------------------
TCVAR:ARG:ゆきずりセックス_覗きフラグ = 1
TIME += 12

;覗き見3分とイベント経過12分を合わせて15分進行
CALL ゆきずりセックス_絶頂値更新_攻め(ARG, 15)

PRINTFORM 物陰を覗き見ると、
SELECTCASE TCVAR:ARG:ゆきずりセックス_体位
	CASE 1
		PRINTFORML %CALLNAME:ARG%が見知らぬ女の膣を激しく貫いている姿を目撃した。
	CASE 2
		PRINTFORML %CALLNAME:ARG%が見知らぬ女の尻を抱え、後ろの穴を犯している姿を目撃した。
	CASEELSE
		PRINTFORML 見知らぬ女が%CALLNAME:ARG%のペニスに熱心に奉仕している姿を目撃した。
ENDSELECT
PRINTW

CALL ゆきずりセックス_相手女性描写_攻め(ARG)
CALL ゆきずりセックス_行為描写_攻め(ARG)

IF TCVAR:ARG:ゆきずりセックス_絶頂値 > 0
	;行為描写と覗き反応の間に空行を一行挟む
	PRINTL 　
	CALL ゆきずりセックス_覗き反応描写_攻め(ARG)
ELSE
	CALL ゆきずりセックス_相手絶頂描写_攻め(ARG)
ENDIF

CALL ゆきずりセックス_パラメータ変動処理_攻め(ARG, 15)


