;==================================================================================================
@ゆきずりセックス攻め立ち絵更新(ARG, TYPE="顔_")
#FUNCTIONS
;-------------------------------------------------
;「ゆきずりセックス（攻め）」中のグラ表示用一時文字列を生成する。
;表示する差分は以下の4種類。
;  Ｖ前面系：攻め正常位
;  Ｖ後背系：攻め後背位
;  Ａ前面系：攻めＡ正常位
;  Ａ後背系：攻めＡ後背位
;--------------------------------------------------------------------------------------------------
#DIMS TYPE
#DIMS 切り替え用文字列
#DIMS D_NAME
#DIMS 体位
;--------------------------------------------------------------------------------------------------
VARSET LOCAL
VARSET 差分エフェクト

D_NAME '= ""

;顔グラか短冊か確認
切り替え用文字列 '= CSTR:ARG:顔グラ表示切り替え用文字列
SIF TYPE == "短冊_"
	切り替え用文字列 '= CSTR:ARG:短冊グラ表示切り替え用文字列

SIF !IS_ゆきずりセックス中(ARG)
	RETURNF ""

;プレイ内容を前面系・後背系へ分類し、4種の攻め差分へ集約する
SELECTCASE TCVAR:ARG:ゆきずりセックス_体位
	CASE 1 ;Ｖ挿入
		SELECTCASE CSTR:ARG:ゆきずりセックス_プレイ内容
			CASE "後背位", "寝バック", "背面座位", "側位", "背面駅弁", "立ちバック"
				体位 '= "攻め後背位"
			CASEELSE
				体位 '= "攻め正常位"
		ENDSELECT

	CASE 2 ;Ａ挿入
		SELECTCASE CSTR:ARG:ゆきずりセックス_プレイ内容
			CASE "Ａ後背位", "Ａ寝バック", "Ａ背面座位", "Ａ側位", "Ａ背面駅弁", "Ａ立ちバック"
				体位 '= "攻めＡ後背位"
			CASEELSE
				体位 '= "攻めＡ正常位"
		ENDSELECT

	CASEELSE ;奉仕を受けている場合
		;攻め側の基本差分として攻め正常位を使用する
		体位 '= "攻め正常位"
ENDSELECT

;4種の差分が用意されていない場合は既存と同じく欲情差分へ戻す
SIF !ENUMFILES(@"resources/%CSTR:ARG:画像フォルダ%/", @"%切り替え用文字列%_差分_%体位%*.*")
	体位 '= "欲情"

SIF 差分抽出(ARG, TYPE, 切り替え用文字列, 体位) && D_NAME == ""
	D_NAME '= RESULTS

SIF D_NAME != ""
	RETURNF D_NAME
RETURNF ""
