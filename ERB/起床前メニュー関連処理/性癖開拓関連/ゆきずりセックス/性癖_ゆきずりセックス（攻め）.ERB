;==================================================================================================
@性癖開拓チャレンジ処理_ゆきずりセックス（攻め）(ARG)
;-------------------------------------------------
;男性用の性癖「ゆきずりセックス（攻め）」を取得するための処理
;--------------------------------------------------------------------------------------------------
#DIM 興味度
;--------------------------------------------------------------------------------------------------

;攻め側の性癖は男性器所持者（男性・ふたなり女性）が対象
IF !GETBIT(TALENT:ARG:性別, 1)
	RETURN -1
ENDIF

CSTR:ARG:性癖開拓報告_記録文字列 += @"%CALLNAME:PLAYER%は%CALLNAME:ARG%にさりげなく「見知らぬ女性との一夜」を描いたエロ本が渡るように小細工した…<br><br>"

;固有処理
RESULT = 0
CALL 口上変数初期化
TRYCALLFORM 性癖開拓_固有条件_ゆきずりセックス（攻め）_{NO:ARG}(ARG)
LOCAL = RESULT
SIF 口上有無確認(0, 1)
	CSTR:ARG:性癖開拓報告_記録文字列 += @"性癖開拓_固有条件"
IF LOCAL == 1
	CSTR:ARG:性癖開拓報告_記録文字列 += @"<br>%CALLNAME:ARG%は性癖素質[ゆきずりセックス（攻め）(興味)]を取得した<br>"
	性癖素質:ARG:ゆきずりセックス（攻め） = 1
	CALL 履歴データベース登録(CFLAG:ARG:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>性癖素質[ゆきずりセックス（攻め）(興味)]を取得した</font>","うふふ")
	RETURN 1
ELSEIF LOCAL == -1
	RETURN 0
ENDIF

IF 知識素質:ARG:性知識 < 性知識条件_性癖開拓チャレンジ()
	CSTR:ARG:性癖開拓報告_記録文字列 += @"%CALLNAME:ARG%は本を開いてみたが、内容をよく理解できなかったようだ…<br>"
	RETURN -1
ENDIF

興味度 = 10

;プラス補正
SIF TALENT:ARG:性的興味 > 0
	興味度 += 10
SIF TALENT:ARG:性欲 > 0
	興味度 += 10
SIF BASE:ARG:性欲 > 1500
	興味度 += 10
興味度 += ABL:ARG:欲望 * 10
興味度 += MAX(EXP:ARG:Ｃ性交経験_Ｖ挿入, EXP:ARG:Ｃ性交経験_Ａ挿入, EXP:ARG:射精経験) / 10

;マイナス補正
SIF TALENT:ARG:プライド > 0
	興味度 -= 5
SIF TALENT:ARG:羞恥心 > 0
	興味度 -= 10
SIF TALENT:ARG:性的興味 < 0
	興味度 -= 10
SIF TALENT:ARG:性欲 == -1
	興味度 -= 10
SIF TALENT:ARG:自制心 > 1
	興味度 -= 20
SIF TALENT:ARG:抵抗
	興味度 -= 20
SIF TALENT:ARG:一線越えない
	興味度 -= 20
SIF TALENT:ARG:貞操
	興味度 -= 30

LOCAL = MAX(10, 興味度)

;童貞または恋人持ちなら最終確率を半減
SIF !GETBIT(TALENT:ARG:非童貞, 0) || TALENT:ARG:恋人持ち
	LOCAL /= 2
SIF 高速船記録:派遣先登録 == "叡智の殿堂"
	LOCAL += 10
SIF TALENT:ARG:経験豊富 || TALENT:ARG:淫乱
	LOCAL = 100
SIF TALENT:ARG:性欲 == -2
	LOCAL = -1

IF RAND:100 < LOCAL
	CSTR:ARG:性癖開拓報告_記録文字列 += @"…%CALLNAME:ARG%は周囲に誰もいないことを確認すると、こっそり本を開いた。<br><br>"
	CSTR:ARG:性癖開拓報告_記録文字列 += @"そこには旅先で出会ったばかりの女を物陰へ誘い、その場限りの快楽を貪る男の姿が描かれていた。<br>"
	IF TALENT:ARG:貞操 == 1
		CSTR:ARG:性癖開拓報告_記録文字列 += @"貞操を重んじる%CALLNAME:ARG%は初めこそ嫌悪感を抱いたが、しがらみのない刹那的な関係に次第に惹かれていった……<br>"
	ELSE
		CSTR:ARG:性癖開拓報告_記録文字列 += @"見知らぬ相手と欲望だけを交わす気軽さに、%CALLNAME:ARG%はページをめくる手を止められなくなっていた……<br>"
	ENDIF
	CSTR:ARG:性癖開拓報告_記録文字列 += @"<br>%CALLNAME:ARG%は性癖素質[ゆきずりセックス（攻め）(興味)]を取得した<br>"
	性癖素質:ARG:ゆきずりセックス（攻め） = 1
	CALL 履歴データベース登録(CFLAG:ARG:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>性癖素質[ゆきずりセックス（攻め）(興味)]を取得した</font>","うふふ")
	RETURN 1
ELSEIF 興味度 <= 0
	CSTR:ARG:性癖開拓報告_記録文字列 += @"%CALLNAME:ARG%は本を訝しげに眺め、そのままゴミ箱へ投げ捨てた。<br>"
ELSE
	CSTR:ARG:性癖開拓報告_記録文字列 += @"%CALLNAME:ARG%は本を手に取って愉しんだが、新たな性癖になるまでには至らなかったようだ……<br>"
ENDIF

RETURN 0


;==================================================================================================
@性癖段階非同室成長_ゆきずりセックス（攻め）(キャラ番号)
;-------------------------------------------------
;「ゆきずりセックス（攻め）」の性癖レベル上昇処理
;--------------------------------------------------------------------------------------------------
#DIM キャラ番号
;--------------------------------------------------------------------------------------------------
SELECTCASE 性癖素質:キャラ番号:ゆきずりセックス（攻め）
	CASE 1
		SIF EXP:キャラ番号:ゆきずりセックス（攻め）経験 < 30
			RETURN 0
		性癖素質:キャラ番号:ゆきずりセックス（攻め） = 2
		DRAWLINE
		PRINTFORML %CALLNAME:キャラ番号%は見知らぬ女性との気軽な交わりを繰り返し、初対面の相手を誘うことに抵抗を覚えなくなったようだ……
		PRINTL
		PRINTFORML %CALLNAME:キャラ番号%の性癖素質[ゆきずりセックス（攻め）(興味)]は[ゆきずりセックス（攻め）(愛好)]に成長した
		IF TALENT:キャラ番号:貞操 == 1
			PRINTFORML %CALLNAME:キャラ番号%は[貞操観念]を失った……
			TALENT:キャラ番号:貞操 = 0
		ENDIF
		CALL 履歴データベース登録(CFLAG:キャラ番号:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>性癖素質[ゆきずりセックス（攻め）(興味)]が[ゆきずりセックス（攻め）(愛好)]に成長した</font>","うふふ")
		PRINTL
		RETURN 1

	CASE 2
		SIF EXP:キャラ番号:ゆきずりセックス（攻め）経験 < 100
			RETURN 0
		性癖素質:キャラ番号:ゆきずりセックス（攻め） = 3
		DRAWLINE
		PRINTFORML %CALLNAME:キャラ番号%にとって、旅先で手頃な女性を誘い一期一会の快楽を貪ることは、もはや生活の一部になってしまっている……
		PRINTL
		PRINTFORML %CALLNAME:キャラ番号%の性癖素質[ゆきずりセックス（攻め）(愛好)]は[ゆきずりセックス（攻め）(中毒)]に成長した
		IF TALENT:キャラ番号:貞操 == 0
			PRINTFORML %CALLNAME:キャラ番号%は[貞操無頓着]を得た
			TALENT:キャラ番号:貞操 = -1
		ENDIF
		CALL 履歴データベース登録(CFLAG:キャラ番号:人物番号, @"<font color='#%カラーパレット_HTML("薄ピンク")%'>性癖素質[ゆきずりセックス（攻め）(愛好)]が[ゆきずりセックス（攻め）(中毒)]に成長した</font>","うふふ")
		PRINTL
		RETURN 1

	CASE 3
		RETURN 0
ENDSELECT
